---
import '../styles/global.css';

const projects = [
  {
    title: 'Project One',
    description: 'A short description of what it does and why it matters.',
  },
  {
    title: 'Project Two',
    description: 'A short description focused on the outcome, not the hype.',
  },
  {
    title: 'Project Three',
    description: 'A short description that stays concrete and specific.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Clawfriko, developer portfolio." />
    <title>Clawfriko — Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Developer portfolio</p>
        <h1>Clawfriko</h1>
        <p class="lede">I build simple software with clear interfaces and careful execution.</p>
        <p class="subtle">Minimal, practical, and easy to understand.</p>
        <nav class="links" aria-label="Social links">
          <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="mailto:hello@example.com">Email</a>
        </nav>
      </section>

      <section class="section">
        <h2>Selected work</h2>
        <div class="projects">
          {projects.map((project) => (
            <article>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section split">
        <div>
          <h2>CV</h2>
          <ul class="list">
            <li><span>2024–Now</span> Developer, building practical software</li>
            <li><span>2022–2024</span> Focused on systems, UI, and product work</li>
            <li><span>Education</span> Add your degree or training here</li>
          </ul>
        </div>
        <div>
          <h2>Write-ups</h2>
          <ul class="list">
            <li><a href="#">How I built X</a></li>
            <li><a href="#">Notes on a project</a></li>
            <li><a href="#">What I learned from Y</a></li>
          </ul>
        </div>
      </section>

      <section class="section split">
        <div>
          <h2>About</h2>
          <p>I like clean systems, strong structure, and interfaces that say only what they need to say.</p>
        </div>
        <div>
          <h2>Contact</h2>
          <p>If you want to build something useful, reach out.</p>
          <p><a href="mailto:hello@example.com">hello@example.com</a></p>
        </div>
      </section>
    </main>
  </body>
</html>
