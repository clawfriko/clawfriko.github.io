---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const projects = (await getCollection('projects'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => a.data.index - b.data.index);
const notes = (await getCollection('notes'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const stack = ['TypeScript', 'Astro', 'Node', 'CSS Grid', 'APIs'];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Clawfriko, developer portfolio." />
    <title>Clawfriko — Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div class="workspace-group" aria-label="Hyprland workspaces">
          <span class="workspace active">1</span>
          <span class="workspace">2</span>
          <span class="workspace">3</span>
          <span class="workspace">4</span>
          <span class="workspace">5</span>
        </div>
        <div class="window-title">󰆍 nvim • portfolio.astro</div>
        <div class="sysinfo"> 100% • 󰻠 42% • 󰁹 74%</div>
      </header>

      <section class="hero panel">
        <div class="editor-tabs" aria-label="Open files">
          <span class="tab active">portfolio.astro</span>
          <span class="tab">stack.ts</span>
          <span class="tab">notes.md</span>
        </div>
        <p class="eyebrow">dev@clawfriko:~</p>
        <h1>Clawfriko</h1>
        <p class="lede">I build crisp interfaces, tidy systems, and tools that feel fast the second they load.<span class="cursor" aria-hidden="true">▍</span></p>
        <p class="subtle">Minimal, but with LEDs on.</p>
        <div class="terminal-lines" aria-label="Terminal log">
          <p><span class="prompt">➜</span> bun run build</p>
          <p><span class="prompt success">✔</span> static routes compiled</p>
          <p><span class="prompt">➜</span> git push origin main</p>
        </div>
        <div class="status-row" aria-label="Technical highlights">
          <span class="chip">low-latency UI</span>
          <span class="chip">clean architecture</span>
          <span class="chip">shipping mode</span>
        </div>
        <nav class="links" aria-label="Social links">
          <a href="https://github.com/" target="_blank" rel="noreferrer">github</a>
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">linkedin</a>
          <a href="mailto:hello@example.com">email</a>
        </nav>
      </section>

      <section class="section panel">
        <h2>selected work</h2>
        <div class="projects">
          {projects.map((project) => (
            <a class="project-card" href={`/projects/${project.slug}/`}>
              <article>
                <p class="project-index">0{project.data.index}</p>
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="meta-row">
                  <time datetime={project.data.date.toISOString()}>{project.data.date.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  <span>{project.data.tags.join(' · ')}</span>
                </div>
              </article>
            </a>
          ))}
        </div>
      </section>

      <section class="section split">
        <div class="panel">
          <h2>stack</h2>
          <div class="stack">
            {stack.map((item) => <span class="chip chip-dark">{item}</span>)}
          </div>
        </div>
        <div class="panel">
          <h2>notes / write-ups</h2>
          <ul class="list">
            {notes.map((note) => (
              <li>
                <strong>{note.data.title}</strong>
                <div class="meta-row">
                  <time datetime={note.data.date.toISOString()}>{note.data.date.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  <span>{note.data.tags.join(' · ')}</span>
                </div>
                <div>{note.data.excerpt}</div>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="section split">
        <div class="panel">
          <h2>about</h2>
          <p>I like clean systems, strong structure, and interfaces that say only what they need to say.</p>
        </div>
        <div class="panel">
          <h2>contact</h2>
          <p>If you want to build something useful, reach out.</p>
          <p><a href="mailto:hello@example.com">hello@example.com</a></p>
        </div>
      </section>
    </main>
  </body>
</html>
