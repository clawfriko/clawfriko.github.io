---
import '../styles/global.css';

const projects = [
  {
    title: 'Signal Router',
    description: 'A fast path for turning noisy inputs into clean, actionable outputs.',
  },
  {
    title: 'Terminal UI Kit',
    description: 'A component set with sharp spacing, status chips, and glowing accents.',
  },
  {
    title: 'Build Inspector',
    description: 'A tiny dashboard for checking health, latency, and release signals.',
  },
];

const stack = ['TypeScript', 'Astro', 'Node', 'CSS Grid', 'APIs'];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Clawfriko, developer portfolio." />
    <title>Clawfriko — Developer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">Developer portfolio // active build</p>
        <h1>Clawfriko</h1>
        <p class="lede">I build crisp interfaces, tidy systems, and tools that feel fast the second they load.</p>
        <p class="subtle">Minimal, but with LEDs on.</p>
        <div class="status-row" aria-label="Technical highlights">
          <span class="chip">low-latency UI</span>
          <span class="chip">clean architecture</span>
          <span class="chip">shipping mode</span>
        </div>
        <nav class="links" aria-label="Social links">
          <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="mailto:hello@example.com">Email</a>
        </nav>
      </section>

      <section class="section">
        <h2>Selected work</h2>
        <div class="projects">
          {projects.map((project, index) => (
            <article>
              <p class="project-index">0{index + 1}</p>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section split">
        <div>
          <h2>Stack</h2>
          <div class="stack">
            {stack.map((item) => <span class="chip chip-dark">{item}</span>)}
          </div>
        </div>
        <div>
          <h2>Write-ups — Notes & essays</h2>
          <ul class="list">
            <li><a href="#">How I built X</a></li>
            <li><a href="#">Notes on a project</a></li>
            <li><a href="#">What I learned from Y</a></li>
          </ul>
        </div>
      </section>

      <section class="section split">
        <div>
          <h2>About</h2>
          <p>I like clean systems, strong structure, and interfaces that say only what they need to say.</p>
        </div>
        <div>
          <h2>Contact</h2>
          <p>If you want to build something useful, reach out.</p>
          <p><a href="mailto:hello@example.com">hello@example.com</a></p>
        </div>
      </section>
    </main>
  </body>
</html>
